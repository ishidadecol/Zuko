<div class="h-screen flex">

  <!-- Sidebar -->
  <aside class="border-[3px] border-black flex flex-col w-80">
    <!-- Sidebar header -->
    <div class="px-6 py-2 border-b bg-black border-black  flex justify-between items-center">
      <h1 class=" text-zinc-300">
        Notes
      </h1>
      <%= link_to "New Note", new_note_path, data: { turbo_frame: "note_content" }, class: "bg-zinc-800 text-white text-sm px-3 py-1 rounded-md hover:bg-zinc-700" %>
    </div>

    <div class="flex-1 overflow-y-auto">
      <% @notes.each do |note| %>
        <%# The link now points to the root path with the note's id, keeping us on the index page %>
        <%= link_to url_for(controller: :notes, action: :index, id: note.id),
            class: "block px-6 py-4 border-b border-zinc-100 hover:bg-zinc-50 #{'bg-zinc-100' if @note == note}" do %>

          <p class="text-sm font-medium text-zinc-900 truncate">
            <%= note.title.presence || "Untitled" %>
          </p>
          <p class="text-xs text-zinc-500">
            <%= time_ago_in_words(note.updated_at) %> ago
          </p>

        <% end %>
      <% end %>

      <% if @notes.empty? %>
        <div class="px-6 py-6 text-sm text-zinc-500">
          No notes yet.
          <%= link_to "Create one!", new_note_path, class: "text-blue-500 hover:underline" %>
        </div>
      <% end %>
    </div>

  </aside>

  <!-- Main Content -->
  <main class="flex-1 p-[2rem] overflow-y-auto">
    <%= turbo_frame_tag "note_content" do %>
      <% if @note %>
        <div class="flex justify-between items-start">
          <h1 class="text-3xl font-semibold mb-4"><%= @note.title.presence || "Untitled" %></h1>
          <div class="flex space-x-2">
            <%= link_to "Edit", url_for(controller: :notes, action: :edit, id: @note.id), data: { turbo_frame: "note_content" }, class: "bg-zinc-200 text-zinc-800 px-4 py-2 rounded-md hover:bg-zinc-300" %>
            <%= button_to "Delete", url_for(controller: :notes, action: :destroy, id: @note.id), method: :delete, form: { data: { turbo_frame: "_top" } }, class: "bg-red-500 text-white px-4 py-2 rounded-md hover:bg-red-600" %>
          </div>
        </div>
        <div class="prose max-w-none mt-[2rem]">
          <%= @note.content %>
        </div>
      <% else %>
        <div class="flex items-center justify-center h-full">
            <div class= "min-w-[30rem] h-[18rem] border-t-[3px] border-l-[3px] border-r-[5px] border-b-[5px] border-black p-[2rem]">
              <%= image_tag "ghost_icon.svg", class: "w-15 mb-4 mx-auto" %>
              <h2 class="text-2xl font-black mb-2 text-center">
               No note selected
              </h2>
              <div class="h-[5px] bg-black mt-3 mb-3 flex"></div>
              <p class="text-zinc-500 text-center">
               Select a note to view it, <br/>or create a new one.
              </p>
            </div>
        </div>
      <% end %>
    <% end %>
  </main>

  <!-- Tools -->
  <aside class="border border-black flex flex-col">

    <div class="flex-1 overflow-y-auto">
       <div class= "block px-6 py-4 border-b border-zinc-100 hover:bg-zinc-50">
          <p class="text-sm font-medium text-zinc-900 truncate">
              Add to flash cards
          </p>
        </div>

        <div class= "block px-6 py-4 border-b border-zinc-100 hover:bg-zinc-50">
          <p class="text-sm font-medium text-zinc-900 truncate">
              Generate quiz
          </p>
        </div>
    </div>

  </aside>

</div>
