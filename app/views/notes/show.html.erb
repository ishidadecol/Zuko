<div class="min-h-screen flex py-4 px-4">
  <div class="w-full max-w-2xl bg-white shadow-xl rounded-2xl p-8 space-y-6">

    <p class="text-gray-600 tracking-tight">
      <%@note.title%>
    </p>

    <%= form_with model: @note, class: "space-y-6 gap-4 flex flex-col" do |form| %>

      <!-- Title -->
      <div class="space-y-2">
        <%= form.text_field :title, class: "w-full bold text-2xl py-3 " %>
      </div>

      <!-- Content -->
      <div class="space-y-2">
        <div class=" p-3">
          <%= form.rich_textarea :content, class: "prose max-w-none focus:outline-none" %>
        </div>
      </div>

    <% end %>

  </div>
</div>
